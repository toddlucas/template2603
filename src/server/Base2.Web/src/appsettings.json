{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Seq": {
      "ServerUrl": "http://localhost:5341",
      "ApiKey": "1234567890"
    }
  },
  "AllowedHosts": "*",
  "AppDbProvider": "***OVERRIDE***",
  "WarehouseDbProvider": "***OVERRIDE***",
  "HangfireDbProvider": "***OVERRIDE***",
  "IsWriteGuardInterceptorEnabled": true,
  "ConnectionStrings": {
    "SqliteAppDbContextConnection": "***SECRET***",
    "NpgsqlAppDbContextConnection": "***SECRET***",
    "SqliteWarehouseDbContextConnection": "***SECRET***",
    "NpgsqlWarehouseDbContextConnection": "***SECRET***",
    "SqliteDefaultHangfireConnection": "***SECRET***",
    "NpgsqlDefaultHangfireConnection": "***SECRET***"
  },
  "IdentityOptions": {
    "SignIn": {
      "RequireConfirmedEmail": true
    },
    "Password": {
      "RequiredLength": 8
    }
  },
  "AppRateLimit": {
    "PermitLimit": 100
  },
  "AuthSendgridOptions": {
    "SendGridKey": "***SECRET***"
  },
  "ChatClient": {
    "ApiKey": "***SECRET***",
    "Model": "gpt-5-nano"
  },
  "AISettings": {
    "Provider": "OpenAI",
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-5-nano",
      "MaxTokens": 4096
    },
    "RateLimiting": {
      "MaxConcurrentPerTenant": 5,
      "RequestsPerMinutePerUser": 30
    },
    "Cost": {
      "InputTokenCostPer1M": 5.00,
      "OutputTokenCostPer1M": 15.00
    }
  },
  "ExternalAuth": {
    "Microsoft": {
      "ClientId": "",
      "TenantId": "common"
    },
    "Google": {
      "ClientId": ""
    }
  },
  "TrackingSettings": {
    "BaseUrl": "https://app.product.tld"
  },
  "FileStorageSettings": {
    "Provider": "Local",
    "LocalPath": "../../Base2.Web/src/App_Data/imports",
    "MaxFileSizeBytes": 5242880
  },
  "UnsubscribeSettings": {
    "TokenSecret": "CHANGE-THIS-TO-A-SECURE-32-CHAR-SECRET-KEY-FOR-PRODUCTION",
    "TokenLifetimeDays": 90
  }
}
