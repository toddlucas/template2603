# Development Environment Configuration
# Copy this file to .env.development.local to override values

# Application
VITE_APP_TITLE="Product Name - Development"
VITE_BASE_PATH=/

# Authentication
# Electron always uses bearer tokens — there is no same-origin cookie domain.
VITE_AUTH_TYPE=bearer

# Debug Logging - Platform & Infrastructure
# Levels: 0=NONE, 1=ERROR, 2=WARN, 3=INFO, 4=DEBUG, 5=VERBOSE
VITE_LOG_CONFIG=3
VITE_LOG_DI=3
VITE_LOG_EVENT=4
VITE_LOG_PLATFORM=3
VITE_LOG_AUTH=4

# API
VITE_API_BASE_URL=http://localhost:8181

# Microsoft OAuth (Approach A′ — Electron main process)
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=common

# Debug Logging - MVP Features
VITE_LOG_CONTACTS=4
VITE_LOG_SEQUENCES=4
VITE_LOG_AI=4
VITE_LOG_EMAIL=4
VITE_LOG_INBOX=4
VITE_LOG_ANALYTICS=3
