{
  "name": "@product-name/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Product Name Web App",
  "license": "UNLICENSED",
  "author": "Base 2 Team",
  "homepage": "https://product.tld",
  "repository": "https://github.com/base2llc/productrepo",
  "imports": {
    "#mail/*": "./src/apps/mail/*",
    "#onboarding/*": "./src/apps/onboarding/*",
    "@/*": "./src/*",
    "$/*": "../common/src/*"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui --api.port=6173",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@types/papaparse": "^5.5.2",
    "@types/react-dropzone": "^4.2.2",
    "inversify": "^7.6.1",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-router-dom": "^7.6.3",
    "reflect-metadata": "^0.2.1",
    "zod": "^4.2.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.13",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-json5": "^1.2.0",
    "vitest": "^4.0.13"
  }
}
